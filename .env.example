# ---------- Backend ----------
FITFOOD_ENV=production
FITFOOD_DATABASE_URL=sqlite:////app/data/fitfood.db
FITFOOD_CORS_ORIGINS=http://localhost:3030,http://localhost:8000
FITFOOD_SEED_DEMO_DATA=false

# Open Food Facts (бесплатный, без ключа)
FITFOOD_OPEN_FOOD_FACTS_BASE_URL=https://world.openfoodfacts.org
FITFOOD_OFF_USER_AGENT=FitFood/0.1 (support@fitfood.app)

# USDA FoodData Central (бесплатный ключ — https://fdc.nal.usda.gov/api-key-signup.html)
FITFOOD_USDA_BASE_URL=https://api.nal.usda.gov
FITFOOD_USDA_API_KEY=DEMO_KEY

# TheMealDB recipes (ключ 1 подходит для разработки; публичный релиз требует supporter key)
FITFOOD_THEMEALDB_BASE_URL=https://www.themealdb.com/api/json/v1
FITFOOD_THEMEALDB_API_KEY=1
FITFOOD_THEMEALDB_CATALOG_SYNC_ENABLED=true
FITFOOD_THEMEALDB_CATALOG_SYNC_LIMIT=1000
FITFOOD_THEMEALDB_CATALOG_SYNC_LETTERS=a,b,c,d,e,f,g,h,i,j,k,l,m,n,o,p,q,r,s,t,u,v,w,x,y,z

# Backend-only LLM providers (опционально; ключи никогда не кладём во frontend)
FITFOOD_LLM_ENABLED=false
FITFOOD_LLM_PROVIDER=openrouter
FITFOOD_MINIMAX_BASE_URL=https://api.minimax.io
FITFOOD_MINIMAX_API_KEY=
FITFOOD_MINIMAX_MODEL=MiniMax-M3
FITFOOD_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
FITFOOD_OPENROUTER_API_KEY=
FITFOOD_OPENROUTER_MODEL=google/gemma-4-31b-it:free
FITFOOD_OPENROUTER_HTTP_REFERER=
FITFOOD_OPENROUTER_APP_TITLE=FitFood
FITFOOD_LLM_DAILY_REQUEST_BUDGET=100

# ---------- Frontend ----------
# Базовый URL бэка. В compose фронт уже резолвит "backend" через Docker DNS,
# но TanStack Start читает VITE_* только во время build.
# Для локального запуска в браузере указывайте http://localhost:8000/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ---------- Ports ----------
# 3000 часто занят (vite preview в IDE, Docker Desktop и т.п.) — дефолт 3030
BACKEND_PORT=8000
FRONTEND_PORT=3030
